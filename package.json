  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "setup:devnet": "ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=847fcb36-1e59-45de-b3fc-ac7e83a42981 ANCHOR_WALLET=~/.config/solana/id.json yarn ts-node -P tsconfig.json scripts/setup-devnet.ts",
    "crank:devnet": "ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=847fcb36-1e59-45de-b3fc-ac7e83a42981 ANCHOR_WALLET=~/.config/solana/id.json MAINNET_RPC=https://mainnet.helius-rpc.com/?api-key=847fcb36-1e59-45de-b3fc-ac7e83a42981 yarn ts-node -P tsconfig.json scripts/crank.ts",
    "crank:devnet:dry": "ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=847fcb36-1e59-45de-b3fc-ac7e83a42981 ANCHOR_WALLET=~/.config/solana/id.json MAINNET_RPC=https://mainnet.helius-rpc.com/?api-key=847fcb36-1e59-45de-b3fc-ac7e83a42981 DRY_RUN=true yarn ts-node -P tsconfig.json scripts/crank.ts",
    "liquidator:devnet": "ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=847fcb36-1e59-45de-b3fc-ac7e83a42981 ANCHOR_WALLET=~/.config/solana/id.json yarn ts-node -P tsconfig.json scripts/liquidator.ts",
    "liquidator:devnet:dry": "ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=847fcb36-1e59-45de-b3fc-ac7e83a42981 ANCHOR_WALLET=~/.config/solana/id.json DRY_RUN=true yarn ts-node -P tsconfig.json scripts/liquidator.ts",
    "build:testing": "anchor build -- --features testing",
    "deploy:testing": "anchor build -- --features testing && anchor deploy --provider.cluster devnet",
    "test:e2e": "ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=847fcb36-1e59-45de-b3fc-ac7e83a42981 ANCHOR_WALLET=~/.config/solana/id.json MAINNET_RPC=https://mainnet.helius-rpc.com/?api-key=847fcb36-1e59-45de-b3fc-ac7e83a42981 yarn ts-node -P tsconfig.json scripts/test-e2e.ts",
    "verify:drift": "MAINNET_RPC=https://mainnet.helius-rpc.com/?api-key=847fcb36-1e59-45de-b3fc-ac7e83a42981 ANCHOR_WALLET=~/.config/solana/id.json yarn ts-node -P tsconfig.json scripts/verify-drift-indices.ts",
    "crank:demo": "ANCHOR_PROVIDER_URL=https://api.devnet.solana.com ANCHOR_WALLET=~/.config/solana/id.json yarn ts-node -P tsconfig.json scripts/crank-devnet.ts",
    "crank:demo:fast": "ANCHOR_PROVIDER_URL=https://api.devnet.solana.com ANCHOR_WALLET=~/.config/solana/id.json INTERVAL_MS=60000 yarn ts-node -P tsconfig.json scripts/crank-devnet.ts",
    "reset:oracle": "ANCHOR_PROVIDER_URL=https://api.devnet.solana.com ANCHOR_WALLET=~/.config/solana/id.json yarn ts-node -P tsconfig.json scripts/reset-oracle.ts"
